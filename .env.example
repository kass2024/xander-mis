# Copy to .env — never commit .env
APP_URL=https://xanderglobalscholars.com

OPENAI_API_KEY=

FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=https://xanderbot.site/auth/facebook/callback
FB_GRAPH_VERSION=v19.0

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://xanderbot.site/admin/meta/callback
META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_VERSION=v19.0

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Proxy Meta webhooks to VPS FAQ bot (if callback still points at cPanel /api/whatsapp-webhook.php)
XANDERBOT_WEBHOOK_URL=https://xanderbot.site/api/webhook/meta
# Optional fallback when numbers omit +country (one deployment = one code). Leave empty for international + only.
# WHATSAPP_DEFAULT_COUNTRY_CODE=
# Meta language for xander_prescreening_invite (usually en, not en_US)
WHATSAPP_PRESCREENING_INVITE_TEMPLATE_LANG=en

PRESCREENING_FORWARD_SECRET=
PRESCREENING_STAFF_WHATSAPP=12704387305,254711807646

# Set to 1 to auto-create/upgrade pre-screening tables on each DB connection
# XANDER_AUTO_SCHEMA=1

# Cron: scripts/spam_guard_purge_all.php (see scripts/CPANEL_CRON.txt)
# SPAM_GUARD_CRON_SECRET=

# SMTP (payment / admissions email)
SMTP_HOST=xanderglobalscholars.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Xander Global Scholars

# Stripe (card payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# MTN Mobile Money via ItecPay (Rwanda)
MOMO_ITECPAY_API_KEY=
MOMO_CALLBACK_SECRET=
MOMO_ITECPAY_PAY_URL=https://pay.itecpay.rw/api2/pay
MOMO_ITECPAY_VERIFY_URL=https://pay.itecpay.rw/api2/verify
